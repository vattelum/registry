# Frontend environment for the on-chain Registry.
#
# Defaults point at the live demo registry on Sepolia — copy to .env and
# `npm run dev` to browse it as-is. Replace VITE_REGISTRY_ADDRESS with your
# own contract when you deploy your own Registry.

# Deployed Registry contract address (filled in after running apps/contracts/script/Deploy.s.sol)
VITE_REGISTRY_ADDRESS=0xF3f36F7961C6258688e7d333e64818bC6236fd8E

# Initial admin wallet address (used for client-side isAdmin gating without an extra contract call;
# the contract `admin()` getter remains the on-chain source of truth and is consulted on connect)
VITE_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

# Chain ID: 11155111 for Sepolia, 1 for Ethereum mainnet
VITE_CHAIN_ID=11155111

# Public RPC endpoint for your target network
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Arweave uploads use the connected wallet via ArDrive Turbo — no private key needed.
